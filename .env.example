OPENAI_API_KEY=sk-...
# Optional overrides:
# OPENAI_BASE_URL=https://api.openai.com/v1
# STT_MODEL=gpt-4o-mini-transcribe
# CHAT_MODEL=gpt-4.1-mini
# TTS_MODEL=gpt-4o-mini-tts
# TTS_VOICE=alloy
# RECORD_SECONDS=5
# SAMPLE_RATE=16000
# INPUT_DEVICE=hw:1,0
# OUTPUT_DEVICE=hw:0,0
# SYSTEM_PROMPT=You are AIYVoice, a concise, helpful home voice assistant.
# MAX_TURNS=6

# Optional: disable speaker playback when output sink is unavailable
# DISABLE_AUDIO_PLAYBACK=1
